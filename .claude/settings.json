{
  "permissions": {
    "allow": [
      "Bash(cargo:*)",
      "Bash(npm:*)",
      "Bash(npx:*)",
      "Bash(node:*)",
      "Bash(git status)",
      "Bash(git diff*)",
      "Bash(git log*)",
      "Bash(git add*)",
      "Bash(git commit*)",
      "Bash(git checkout*)",
      "Bash(git branch*)",
      "Bash(find docs*)",
      "Bash(ls*)",
      "Bash(cat proto/*)",
      "Bash(mkdir -p crates/*)",
      "Bash(mkdir -p proto)",
      "Bash(apt-get install -y libsvtav1-dev)",
      "Bash(apt-get install -y coturn)",
      "Bash(protoc:*)"
    ],
    "deny": [
      "Bash(rm -rf *)",
      "Bash(curl*)",
      "Bash(wget*)",
      "Bash(git push*)",
      "Bash(git reset --hard*)",
      "Bash(git clean -f*)",
      "Bash(sudo rm*)",
      "Bash(chmod 777*)"
    ]
  },
  "hooks": {
    "PreToolUse": [
      {
        "matcher": "Bash",
        "hooks": [
          {
            "type": "command",
            "command": "echo '[prism-agent] executando: $CLAUDE_TOOL_INPUT_COMMAND'"
          }
        ]
      }
    ],
    "PostToolUse": [
      {
        "matcher": "Write",
        "hooks": [
          {
            "type": "command",
            "command": "if echo '$CLAUDE_TOOL_INPUT_FILE_PATH' | grep -q '\\.rs$'; then cd \"$(dirname $CLAUDE_TOOL_INPUT_FILE_PATH)\" && cargo clippy 2>&1 | head -20; fi"
          }
        ]
      }
    ]
  }
}
